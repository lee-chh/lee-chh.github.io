</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem 1.25rem;
    text-align: center;
    color: var(--color-muted);
    font-size: 0.875rem;
  }

  .site-footer p {
    margin: 0;
  }
</style>
